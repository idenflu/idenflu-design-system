{
  "version": "2026-06-06",
  "components": {
    "buttons": {
      "label": "Button API",
      "props": ["variant", "size", "icon", "loading", "disabled"],
      "states": ["default", "hover", "focus", "selected", "loading", "disabled", "danger"],
      "accessibility": ["button element", "aria-busy for loading", "aria-label for icon-only"]
    },
    "icons": {
      "label": "Icon API",
      "props": ["symbol", "size", "stroke", "decorative", "label"],
      "states": ["decorative", "informative", "action", "disabled", "selected"],
      "accessibility": ["aria-hidden for decoration", "aria-label for icon-only action", "stable symbol id"]
    },
    "inputs": {
      "label": "Input API",
      "props": ["type", "label", "helper", "validation", "availability"],
      "states": ["default", "focus", "filled", "invalid", "success", "readonly", "disabled"],
      "accessibility": ["visible label", "aria-invalid", "aria-describedby", "combobox relation when searchable"]
    },
    "controls": {
      "label": "Control API",
      "props": ["label", "value", "checked", "group", "helper"],
      "states": ["checked", "selected", "indeterminate", "disabled", "focus"],
      "accessibility": ["native input", "group label", "aria-checked where needed", "keyboard path"]
    },
    "tabs": {
      "label": "Tab API",
      "props": ["tabs", "selected", "panel", "disabled", "overflow"],
      "states": ["selected", "hover", "focus", "disabled", "loading panel"],
      "accessibility": ["role tablist", "aria-selected", "aria-controls", "arrow key navigation"]
    },
    "cards": {
      "label": "Card API",
      "props": ["header", "body", "footer", "metadata", "action"],
      "states": ["default", "hover", "selected", "loading", "locked", "error"],
      "accessibility": ["card action separation", "visible metadata", "focus target", "semantic heading"]
    },
    "table": {
      "label": "Table API",
      "props": ["density", "selection", "sorting", "row state", "responsive"],
      "states": ["default", "selected", "expanded", "loading", "error", "locked"],
      "accessibility": ["role table", "columnheader", "aria-sort", "row action without hover"]
    },
    "overlays": {
      "label": "Overlay API",
      "props": ["trigger", "surface", "backdrop", "placement", "close rule"],
      "states": ["closed", "open", "pending", "validation", "locked", "destructive"],
      "accessibility": ["role dialog", "aria-modal", "aria-labelledby", "focus trap", "focus restore"]
    },
    "feedback": {
      "label": "Feedback API",
      "props": ["tone", "message", "reason", "action", "live region"],
      "states": ["info", "success", "warning", "error", "loading", "locked"],
      "accessibility": ["role status or alert", "visible reason", "recovery action label"]
    },
    "navigation": {
      "label": "Navigation API",
      "props": ["landmark", "items", "current", "count", "pagination"],
      "states": ["active", "hover", "focus", "disabled", "collapsed", "current page"],
      "accessibility": ["nav landmark", "aria-current", "toolbar label", "pagination label"]
    },
    "examples": {
      "label": "Example Composition API",
      "props": ["scenario", "component mix", "metadata", "decision action", "recovery state"],
      "states": ["default", "review", "blocked", "permission", "empty", "error"],
      "accessibility": ["visible scenario heading", "keyboard order follows screen flow", "recovery action label"]
    },
    "menu": {
      "label": "Menu API",
      "props": ["trigger", "items", "group", "checked item", "danger item"],
      "states": ["closed", "open", "hover", "focus", "checked", "disabled", "danger"],
      "accessibility": ["aria-haspopup", "aria-expanded", "role menu", "menuitem", "Escape closes"]
    },
    "combobox": {
      "label": "Combobox API",
      "props": ["label", "query", "options", "active option", "selection"],
      "states": ["collapsed", "expanded", "typing", "active", "empty", "loading", "disabled"],
      "accessibility": ["role combobox", "aria-controls", "aria-activedescendant", "keyboard option navigation"]
    },
    "badges": {
      "label": "Badge API",
      "props": ["tone", "label", "count", "removable", "status"],
      "states": ["neutral", "info", "success", "warning", "danger", "selected", "disabled"],
      "accessibility": ["text visible", "status not color-only", "remove button aria-label"]
    },
    "tooltips": {
      "label": "Tooltip API",
      "props": ["trigger", "content", "placement", "interactive", "delay"],
      "states": ["hidden", "visible", "hover", "focus", "pinned", "disabled"],
      "accessibility": ["aria-describedby", "focus trigger", "no critical action inside tooltip", "popover close path"]
    },
    "avatar": {
      "label": "Avatar API",
      "props": ["name", "image", "initials", "size", "presence", "subtitle"],
      "states": ["image", "initials", "unassigned", "online", "busy", "disabled"],
      "accessibility": ["img alt when informative", "decorative avatar hidden", "visible name near identity rows"]
    },
    "search-toolbar": {
      "label": "Search Toolbar API",
      "props": ["query", "filters", "saved view", "density", "reset"],
      "states": ["empty query", "typing", "filtered", "saved", "loading", "disabled"],
      "accessibility": ["search landmark or label", "filter button names", "active filter text", "reset action"]
    },
    "attachments": {
      "label": "Attachment API",
      "props": ["file name", "file type", "size", "progress", "preview", "action"],
      "states": ["empty", "uploading", "complete", "failed", "scanning", "disabled"],
      "accessibility": ["file input label", "progress text", "error reason", "remove action aria-label"]
    },
    "date-time": {
      "label": "Date Time API",
      "props": ["value", "timezone", "range", "min date", "validation"],
      "states": ["empty", "selected", "range", "disabled date", "invalid", "readonly"],
      "accessibility": ["visible label", "timezone text", "aria-invalid", "keyboard date navigation"]
    },
    "stepper": {
      "label": "Stepper API",
      "props": ["steps", "current step", "status", "optional", "action"],
      "states": ["not started", "current", "complete", "blocked", "optional", "error"],
      "accessibility": ["ordered list", "aria-current step", "visible status", "blocked reason"]
    },
    "empty-states": {
      "label": "Empty State API",
      "props": ["tone", "title", "reason", "primary action", "secondary action"],
      "states": ["empty", "filtered empty", "error", "permission", "locked", "loading"],
      "accessibility": ["clear heading", "recovery action", "alert role for errors", "permission reason visible"]
    }
  }
}
