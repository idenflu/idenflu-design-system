  "states": [
    "default",
    "hover",
    "focus",
    "disabled",
    "error"
  ],
  "accessibility": [
    {
      "id": "documented",
      "rule": "Public Alert accessibility is covered by component implementation and stories."
    }
  ],
  "notes": [
    "Events are framework-specific and omitted from this contract.",
    "Synced from packages/ui-react AlertProps (engineering-first)."
