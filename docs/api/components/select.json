{
  "id": "select",
  "label": "Select",
  "status": "implemented",
  "props": [
    {
      "name": "children",
      "kind": "node",
      "required": false
    },
    {
      "name": "className",
      "kind": "string",
      "required": false
    },
    {
      "name": "defaultOpen",
      "kind": "boolean",
      "required": false
    },
    {
      "name": "defaultValue",
      "kind": "string",
      "required": false
    },
    {
      "name": "disabled",
      "kind": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "error",
      "kind": "string",
      "required": false
    },
    {
      "name": "fullWidth",
      "kind": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "helperText",
      "kind": "string",
      "required": false
    },
    {
      "name": "id",
      "kind": "string",
      "required": false
    },
    {
      "name": "label",
      "kind": "node",
      "required": false
    },
    {
      "name": "name",
      "kind": "string",
      "required": false
    },
    {
      "name": "open",
      "kind": "boolean",
      "required": false
    },
    {
      "name": "options",
      "kind": "unknown",
      "required": false,
      "description": "SelectOption[] alternative to SelectItem children."
    },
    {
      "name": "placeholder",
      "kind": "string",
      "required": false,
      "default": "Select"
    },
    {
      "name": "readOnly",
      "kind": "boolean",
      "required": false,
      "default": false
    },
    {
      "name": "required",
      "kind": "boolean",
      "required": false
    },
    {
      "name": "size",
      "kind": "enum",
      "values": ["lg", "md", "sm"],
      "required": false,
      "default": "md"
    },
    {
      "name": "value",
      "kind": "string",
      "required": false
    },
    {
      "name": "variant",
      "kind": "enum",
      "values": ["default", "filled", "outlined"],
      "required": false,
      "default": "default"
    }
  ],
  "states": ["default", "disabled", "error", "open"],
  "accessibility": [
    {
      "id": "visible-label",
      "rule": "Provide a visible label or accessible name for the select field."
    },
    {
      "id": "listbox-select",
      "rule": "Use Radix Select listbox semantics with keyboard access and typeahead."
    }
  ],
  "notes": [
    "Events (onOpenChange, onValueChange) are framework-specific and omitted.",
    "searchable/filter is not supported on Radix Select; use a Combobox pattern instead.",
    "Synced from packages/ui-react SelectProps (engineering-first)."
  ]
}
