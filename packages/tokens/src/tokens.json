{
  "$schema": "https://tokens.studio/schemas/tokens.json",
  "version": "alpha",
  "name": "idenflu-design-system",
  "description": "Design tokens for idenflu product interfaces.",
  "colors": {
    "primary": { "value": "#3F6DF6", "type": "color", "role": "CTA, selected state, focus, key links" },
    "primary-hover": { "value": "#315FE6", "type": "color" },
    "primary-pressed": { "value": "#264AB8", "type": "color" },
    "primary-soft": { "value": "#EDF4FF", "type": "color", "role": "selected filter, low-risk highlight" },
    "accent-coral": { "value": "#E3563F", "type": "color", "role": "review, attention, revision request" },
    "accent-coral-soft": { "value": "#FFE9E4", "type": "color" },
    "accent-mint": { "value": "#009F7A", "type": "color", "role": "approved, live, healthy" },
    "accent-mint-soft": { "value": "#DFF8EF", "type": "color" },
    "accent-amber": { "value": "#F0A000", "type": "color", "role": "pending, scheduled, deadline risk" },
    "accent-amber-soft": { "value": "#FFF0C7", "type": "color" },
    "accent-amber-ink": { "value": "#9B5B00", "type": "color" },
    "ink": { "value": "#0B1220", "type": "color" },
    "ink-muted": { "value": "#566173", "type": "color" },
    "ink-subtle": { "value": "#8792A5", "type": "color" },
    "canvas": { "value": "#FFFFFF", "type": "color" },
    "surface-1": { "value": "#F7F9FC", "type": "color" },
    "surface-2": { "value": "#EEF2F7", "type": "color" },
    "surface-raised": { "value": "#FFFFFF", "type": "color" },
    "inverse-canvas": { "value": "#050505", "type": "color" },
    "inverse-surface-1": { "value": "#111113", "type": "color" },
    "inverse-ink": { "value": "#FFFFFF", "type": "color" },
    "inverse-ink-muted": { "value": "#AEB8C8", "type": "color" },
    "hairline": { "value": "#D5DCE8", "type": "color" },
    "hairline-strong": { "value": "#A8B2C3", "type": "color" },
    "semantic-success": { "value": "#009F7A", "type": "color" },
    "semantic-warning": { "value": "#F0A000", "type": "color" },
    "semantic-error": { "value": "#D04B55", "type": "color" },
    "semantic-info": { "value": "#3F6DF6", "type": "color" }
  },
  "themes": {
    "light": {
      "canvas": "#FFFFFF",
      "surface-1": "#F7F9FC",
      "surface-2": "#EEF2F7",
      "surface-raised": "#FFFFFF",
      "ink": "#0B1220",
      "ink-muted": "#566173",
      "hairline": "#D5DCE8",
      "chrome": "rgba(255, 255, 255, 0.94)"
    },
    "dark": {
      "canvas": "#000000",
      "surface-1": "#0A0A0B",
      "surface-2": "#141416",
      "surface-raised": "#080809",
      "ink": "#F7F9FD",
      "ink-muted": "#C4CEDD",
      "hairline": "#292B30",
      "chrome": "rgba(0, 0, 0, 0.94)"
    }
  },
  "typography": {
    "display-xl": { "fontFamily": "Pretendard", "fontSize": "68px", "fontWeight": 650, "lineHeight": 1.06, "letterSpacing": 0 },
    "display-lg": { "fontFamily": "Pretendard", "fontSize": "56px", "fontWeight": 650, "lineHeight": 1.1, "letterSpacing": 0 },
    "display-md": { "fontFamily": "Pretendard", "fontSize": "40px", "fontWeight": 650, "lineHeight": 1.16, "letterSpacing": 0 },
    "headline": { "fontFamily": "Pretendard", "fontSize": "30px", "fontWeight": 650, "lineHeight": 1.22, "letterSpacing": 0 },
    "card-title": { "fontFamily": "Pretendard", "fontSize": "21px", "fontWeight": 650, "lineHeight": 1.34, "letterSpacing": 0 },
    "subhead": { "fontFamily": "Pretendard", "fontSize": "18px", "fontWeight": 500, "lineHeight": 1.48, "letterSpacing": 0 },
    "body": { "fontFamily": "Pretendard", "fontSize": "15px", "fontWeight": 450, "lineHeight": 1.55, "letterSpacing": 0 },
    "body-sm": { "fontFamily": "Pretendard", "fontSize": "13px", "fontWeight": 450, "lineHeight": 1.46, "letterSpacing": 0 },
    "body-emphasis": { "fontFamily": "Pretendard", "fontSize": "13px", "fontWeight": 650, "lineHeight": 1.46, "letterSpacing": 0 },
    "caption": { "fontFamily": "Pretendard", "fontSize": "12px", "fontWeight": 500, "lineHeight": 1.34, "letterSpacing": 0 },
    "button": { "fontFamily": "Pretendard", "fontSize": "14px", "fontWeight": 450, "lineHeight": 1.28, "letterSpacing": 0 },
    "eyebrow": { "fontFamily": "Pretendard", "fontSize": "12px", "fontWeight": 650, "lineHeight": 1.34, "letterSpacing": 0 }
  },
  "spacing": {
    "xxs": "4px",
    "xs": "8px",
    "sm": "12px",
    "md": "16px",
    "lg": "20px",
    "xl": "24px",
    "xxl": "32px",
    "xxxl": "40px",
    "section": "88px"
  },
  "sizing": {
    "control-height-sm": "32px",
    "control-height": "38px",
    "control-height-lg": "44px",
    "field-height": "40px",
    "compact-control-height": "32px"
  },
  "density": {
    "compact": { "controlHeight": "32px", "rowHeight": "40px", "gap": "8px", "use": "tables, toolbars, repeated row actions" },
    "comfortable": { "controlHeight": "38px", "fieldHeight": "40px", "gap": "12px", "use": "default dashboard, forms, detail panels" },
    "spacious": { "controlHeight": "44px", "rowHeight": "48px", "gap": "20px", "use": "modal decisions, critical approvals, recovery flows" }
  },
  "radius": {
    "none": "0px",
    "xs": "0px",
    "sm": "0px",
    "md": "0px",
    "lg": "0px",
    "pill": "0px",
    "full": "0px"
  },
  "shadow": {
    "none": "none",
    "low": "0 1px 2px rgba(11, 18, 32, 0.05)",
    "panel": "0 18px 48px rgba(11, 18, 32, 0.14)"
  },
  "motion": {
    "duration-fast": "120ms",
    "duration-base": "200ms",
    "duration-slow": "320ms",
    "ease-standard": "cubic-bezier(0.2, 0, 0, 1)",
    "ease-emphasized": "cubic-bezier(0.3, 0, 0, 1.4)"
  },
  "layering": {
    "base": 0,
    "dropdown": 1000,
    "sticky": 1100,
    "overlay": 1200,
    "modal": 1300,
    "popover": 1400,
    "toast": 1500
  },
  "components": {
    "button-primary": { "height": "{sizing.control-height}", "padding": "9px 14px", "backgroundColor": "{colors.primary}", "textColor": "{colors.inverse-ink}", "typography": "{typography.button}", "radius": "{radius.md}" },
    "button-secondary": { "height": "{sizing.control-height}", "padding": "9px 14px", "backgroundColor": "{colors.inverse-canvas}", "textColor": "{colors.inverse-ink}", "typography": "{typography.button}", "radius": "{radius.md}" },
    "button-quiet": { "height": "{sizing.control-height}", "padding": "9px 14px", "backgroundColor": "{colors.surface-1}", "textColor": "{colors.ink}", "typography": "{typography.button}", "radius": "{radius.md}" },
    "button-ghost": { "height": "{sizing.control-height}", "padding": "9px 12px", "backgroundColor": "transparent", "textColor": "{colors.primary}", "typography": "{typography.button}", "radius": "{radius.md}" },
    "icon-button": { "size": "{sizing.control-height}", "backgroundColor": "{colors.surface-raised}", "textColor": "{colors.ink-muted}", "typography": "{typography.button}", "radius": "{radius.none}" },
    "text-input": { "height": "{sizing.field-height}", "padding": "9px 11px", "backgroundColor": "{colors.surface-raised}", "textColor": "{colors.ink}", "typography": "{typography.body}", "radius": "{radius.md}" },
    "data-table": { "backgroundColor": "{colors.surface-raised}", "textColor": "{colors.ink}", "typography": "{typography.body-sm}", "radius": "{radius.md}", "padding": "0" },
    "status-chip": { "padding": "5px 9px", "backgroundColor": "{colors.surface-1}", "textColor": "{colors.ink-muted}", "typography": "{typography.caption}", "radius": "{radius.none}" },
    "modal-panel": { "padding": "24px", "backgroundColor": "{colors.surface-raised}", "textColor": "{colors.ink}", "typography": "{typography.body}", "radius": "{radius.md}" }
  },
  "icons": {
    "viewBox": "0 0 24 24",
    "strokeWidth": 1.8,
    "strokeLinecap": "square",
    "strokeLinejoin": "miter",
    "symbols": [
      "icon-plus",
      "icon-filter",
      "icon-download",
      "icon-check",
      "icon-x",
      "icon-refresh",
      "icon-more",
      "icon-search",
      "icon-calendar",
      "icon-user",
      "icon-file",
      "icon-table",
      "icon-alert",
      "icon-settings",
      "icon-lock"
    ]
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  }
}
